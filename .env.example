NEO4J_PASSWORD=changeme
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Embedding model — choose a provider and model
# Provider: openai (default) or ollama
EMBEDDING_PROVIDER=openai

# Model name. Defaults: openai→text-embedding-3-small, ollama→nomic-embed-code
# EMBEDDING_MODEL=text-embedding-3-small

# Vector dimensions. Must match the model. Defaults are inferred for known models.
# Change this only if using a model not in the built-in lookup table.
# EMBEDDING_DIM=1536

# Ollama base URL (only used when EMBEDDING_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434
